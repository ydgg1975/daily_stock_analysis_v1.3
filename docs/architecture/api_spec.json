{
  "openapi": "3.0.0",
  "info": {
    "title": "Daily Stock Analysis API",
    "description": "Daily Stock Analysis API for stock analysis, history, market data, and system configuration.",
    "version": "1.0.0",
    "contact": {
      "name": "Daily Stock Analysis Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health check endpoints"
    },
    {
      "name": "Analysis",
      "description": "Stock analysis endpoints"
    },
    {
      "name": "History",
      "description": "Historical report endpoints"
    },
    {
      "name": "SystemConfig",
      "description": "System configuration endpoints"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["Health"],
        "summary": "API root",
        "description": "Returns basic API status information.",
        "responses": {
          "200": {
            "description": "API is running"
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns service health status.",
        "responses": {
          "200": {
            "description": "Service is healthy"
          }
        }
      }
    },
    "/api/v1/analysis/analyze": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Start stock analysis",
        "description": "Starts an AI stock analysis task for one or more stock codes.",
        "responses": {
          "200": {
            "description": "Analysis completed or task accepted"
          },
          "409": {
            "description": "Duplicate analysis task"
          },
          "500": {
            "description": "Analysis failed"
          }
        }
      }
    },
    "/api/v1/history": {
      "get": {
        "tags": ["History"],
        "summary": "List analysis history",
        "description": "Returns paginated analysis history.",
        "responses": {
          "200": {
            "description": "History returned"
          }
        }
      }
    },
    "/api/v1/system-config": {
      "get": {
        "tags": ["SystemConfig"],
        "summary": "Read system configuration",
        "description": "Returns grouped system configuration fields.",
        "responses": {
          "200": {
            "description": "Configuration returned"
          }
        }
      }
    }
  }
}
