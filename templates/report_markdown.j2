{% for e in enriched %}
{% set result = e.result %}
{% set std = e.standard_report %}
{% set decision = std.decision_panel %}
{% set reason = std.reason_layer %}
{% set coverage = std.coverage_notes %}
{% set summary = std.channel_summary %}
{% set highlights = std.highlights if std.highlights is not none else {} %}
{% set market_fields = std.market.display_fields or std.market.regular_fields %}
{% set critical_na_keywords = [
  'pe', '市盈率', 'revenue', '营收', 'net income', '净利润', 'roe', 'fcf', 'free cash flow', '自由现金流',
  'vwap', 'avg price', '平均价', '均价', 'beta', '贝塔',
  'analysis price', 'current price', '当前价', 'prev close', '昨收',
  'ma5', 'ma10', 'ma20', 'ma60', 'rsi', 'volume ratio', 'turnover rate', '量比', '换手率', '趋势强度'
] %}
{% set evidence_groups = [market_fields, std.market.extended_fields, std.technical_fields, std.fundamental_fields, std.earnings_fields] %}
{% set audit = namespace(entries=[]) %}
{%- for fields in evidence_groups %}
{%- for item in fields or [] %}
{% set raw_value = (item.value|string).strip() %}
{% if raw_value.startswith('NA（') and raw_value.endswith('）') %}
{% set entry = {'field': (item.label|string).strip(), 'reason': raw_value[3:-1].strip()} %}
{% if entry not in audit.entries %}
{% set audit.entries = audit.entries + [entry] %}
{% endif %}
{% endif %}
{%- endfor %}
{%- endfor %}
{%- for note in coverage.missing_field_notes or [] %}
{% set normalized_note = (note|string).replace('：', ':') %}
{% set field = '' %}
{% set reason = '接口未返回' %}
{% if ':' in normalized_note %}
{% set parts = normalized_note.split(':', 1) %}
{% set field = (parts[0]|string).strip() %}
{% set reason = (parts[1]|string).strip() %}
{% else %}
{% set field = normalized_note.strip() %}
{% endif %}
{% if reason.startswith('NA（') and reason.endswith('）') %}
{% set reason = reason[3:-1].strip() %}
{% endif %}
{% if field %}
{% set entry = {'field': field, 'reason': reason} %}
{% if entry not in audit.entries %}
{% set audit.entries = audit.entries + [entry] %}
{% endif %}
{% endif %}
{%- endfor %}
{% set missing_by_reason = namespace(
  integrated_unavailable=[],
  not_integrated_yet=[],
  source_not_provided=[],
  not_applicable=[]
) %}
{% set missing_by_priority = namespace(high=[], medium=[], low=[], additional=[]) %}
{%- for entry in audit.entries %}
{% set reason_text = (entry.reason|string).strip() %}
{% set reason_lower = reason_text|lower %}
{% if '不适用' in reason_text
  or '当前市场不支持' in reason_text
  or '当前市场暂不支持' in reason_text
  or '会话不适用' in reason_text
  or 'not applicable' in reason_lower
  or 'market not supported' in reason_lower
  or 'session not applicable' in reason_lower %}
{% set missing_by_reason.not_applicable = missing_by_reason.not_applicable + [entry] %}
{% elif '字段待接入' in reason_text
  or '待接入' in reason_text
  or '未接入' in reason_text
  or '未集成' in reason_text
  or '待映射' in reason_text
  or 'not integrated' in reason_lower
  or 'integration pending' in reason_lower
  or 'pending mapping' in reason_lower %}
{% set missing_by_reason.not_integrated_yet = missing_by_reason.not_integrated_yet + [entry] %}
{% elif '数据源未提供' in reason_text
  or '当前数据源未提供' in reason_text
  or '源未提供' in reason_text
  or '供应商未提供' in reason_text
  or 'source not provided' in reason_lower
  or 'provider does not provide' in reason_lower
  or 'provider limitation' in reason_lower %}
{% set missing_by_reason.source_not_provided = missing_by_reason.source_not_provided + [entry] %}
{% else %}
{% set missing_by_reason.integrated_unavailable = missing_by_reason.integrated_unavailable + [entry] %}
{% endif %}

{% set field_text = (entry.field|string).strip() %}
{% set field_lower = field_text|lower %}
{% if '市盈率' in field_text
  or field_lower == 'pe'
  or field_lower.startswith('pe(')
  or ' pe ' in (' ' ~ field_lower ~ ' ')
  or 'p/e' in field_lower
  or '营收' in field_text
  or 'revenue' in field_lower
  or '净利润' in field_text
  or 'net income' in field_lower
  or 'roe' in field_lower
  or '自由现金流' in field_text
  or 'fcf' in field_lower
  or 'free cash flow' in field_lower %}
{% if entry not in missing_by_priority.high %}
{% set missing_by_priority.high = missing_by_priority.high + [entry] %}
{% endif %}
{% elif 'vwap' in field_lower
  or 'avg price' in field_lower
  or '平均价' in field_text
  or '均价' in field_text
  or 'beta' in field_lower
  or '贝塔' in field_text %}
{% if entry not in missing_by_priority.medium %}
{% set missing_by_priority.medium = missing_by_priority.medium + [entry] %}
{% endif %}
{% elif '盘前' in field_text
  or 'premarket' in field_lower
  or 'pre-market' in field_lower
  or '盘后' in field_text
  or 'after-hours' in field_lower
  or 'after hours' in field_lower
  or 'extended' in field_lower %}
{% if entry not in missing_by_priority.low %}
{% set missing_by_priority.low = missing_by_priority.low + [entry] %}
{% endif %}
{% else %}
{% if entry not in missing_by_priority.additional %}
{% set missing_by_priority.additional = missing_by_priority.additional + [entry] %}
{% endif %}
{% endif %}
{%- endfor %}
{% set risks = namespace(bullish=[], risk=[], catalysts=[], sentiment=[]) %}
{% if summary.top_bullish_factor and summary.top_bullish_factor != na('接口未返回') %}
{% set risks.bullish = risks.bullish + [summary.top_bullish_factor] %}
{% endif %}
{% if summary.top_risk and summary.top_risk != na('接口未返回') %}
{% set risks.risk = risks.risk + [summary.top_risk] %}
{% endif %}
{% for item in highlights.positive_catalysts or [] %}
{% if item and item not in risks.bullish %}
{% set risks.bullish = risks.bullish + [item] %}
{% endif %}
{% endfor %}
{% for item in highlights.bullish_factors or [] %}
{% if item and item not in risks.bullish %}
{% set risks.bullish = risks.bullish + [item] %}
{% endif %}
{% endfor %}
{% for item in highlights.risk_alerts or [] %}
{% if item and item not in risks.risk %}
{% set risks.risk = risks.risk + [item] %}
{% endif %}
{% endfor %}
{% for item in highlights.bearish_factors or [] %}
{% if item and item not in risks.risk %}
{% set risks.risk = risks.risk + [item] %}
{% endif %}
{% endfor %}
{% for item in highlights.neutral_factors or [] %}
{% if item and item not in risks.catalysts %}
{% set risks.catalysts = risks.catalysts + [item] %}
{% endif %}
{% endfor %}
{% for item in highlights.latest_news or [] %}
{% if item and item not in risks.catalysts %}
{% set risks.catalysts = risks.catalysts + [item] %}
{% endif %}
{% endfor %}
{% if summary.latest_key_update and summary.latest_key_update != na('接口未返回') and summary.latest_key_update not in risks.catalysts %}
{% set risks.catalysts = risks.catalysts + [summary.latest_key_update] %}
{% endif %}
{% if highlights.sentiment_summary and highlights.sentiment_summary != na('接口未返回') %}
{% set risks.sentiment = risks.sentiment + [highlights.sentiment_summary] %}
{% endif %}
{% if highlights.social_synthesis and highlights.social_synthesis != na('接口未返回') and highlights.social_synthesis not in risks.sentiment %}
{% set risks.sentiment = risks.sentiment + [highlights.social_synthesis] %}
{% endif %}
{% if highlights.social_tone and highlights.social_tone not in risks.sentiment %}
{% set risks.sentiment = risks.sentiment + ['Social tone: ' ~ highlights.social_tone] %}
{% endif %}
{% if highlights.social_attention and highlights.social_attention not in risks.sentiment %}
{% set risks.sentiment = risks.sentiment + ['Social attention: ' ~ highlights.social_attention] %}
{% endif %}
{% if highlights.social_narrative_focus and highlights.social_narrative_focus not in risks.sentiment %}
{% set risks.sentiment = risks.sentiment + ['Social narrative: ' ~ highlights.social_narrative_focus] %}
{% endif %}
