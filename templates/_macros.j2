{# Shared macros for report templates #}

{% macro render_field_group(fields, critical_keywords=[]) -%}
{% set empty_group_label = 'See Coverage / Audit (no critical missing fields in this section)' if report_language == 'en' else '详见 Coverage / Audit（当前区块无关键缺失字段）' %}
{% set ns = namespace(lines=[]) %}
{% for item in fields or [] %}
{% set label = (item.label|string).strip() %}
{% set value = (item.value|string).strip() %}
{% set is_reasoned_na = value.startswith('NA（') and value.endswith('）') %}
{% if is_reasoned_na %}
{% set label_lower = label|lower %}
{% set keep_na = namespace(value=false) %}
{% for keyword in critical_keywords %}
{% if keyword and keyword in label_lower %}
{% set keep_na.value = true %}
{% endif %}
{% endfor %}
{% if keep_na.value %}
{% set ns.lines = ns.lines + ['- **' ~ label ~ '**: NA'] %}
{% endif %}
{% else %}
{% set ns.lines = ns.lines + ['- **' ~ label ~ '**: ' ~ value] %}
{% endif %}
{% endfor %}
{% if ns.lines %}
{% for line in ns.lines %}
{{ line }}
{% endfor %}
{% else %}
- {{ empty_group_label }}
{% endif %}
{%- endmacro %}

{% macro compact_list_section(title, lines) -%}
### {{ title }}
{% if lines %}
{% for line in lines %}
- {{ line }}
{% endfor %}
{% else %}
- {{ na('接口未返回') }}
{% endif %}
{%- endmacro %}

{% macro market_snapshot(result) -%}
{% set snapshot = normalize_market_snapshot(result.market_snapshot if result.market_snapshot else {}) %}
{% set session_type_label = 'Session Type' if report_language == 'en' else 'session 类型' %}
{% set consistency_label = 'Consistency Warnings' if report_language == 'en' else '口径校验' %}
### 📈 {{ labels.market_snapshot_heading }}
- **{{ labels.current_price_label }}**: {{ snapshot.get('price', na('接口未返回')) }}
- **{{ labels.prev_close_label }}**: {{ snapshot.get('prev_close', na('接口未返回')) }}
- **{{ labels.open_label }}**: {{ snapshot.get('open', na('接口未返回')) }}
- **{{ labels.high_label }}**: {{ snapshot.get('high', na('接口未返回')) }}
- **{{ labels.low_label }}**: {{ snapshot.get('low', na('接口未返回')) }}
- **{{ labels.change_amount_label }}**: {{ snapshot.get('change_amount', na('接口未返回')) }}
- **{{ labels.change_pct_label }}**: {{ snapshot.get('pct_chg', na('接口未返回')) }}
- **{{ labels.amplitude_label }}**: {{ snapshot.get('amplitude', na('接口未返回')) }}
- **{{ labels.volume_label }}**: {{ snapshot.get('volume', na('当前数据源未提供')) }}
- **{{ labels.amount_label }}**: {{ snapshot.get('amount', na('当前数据源未提供')) }}
- **{{ labels.volume_ratio_label }}**: {{ snapshot.get('volume_ratio', na('当前数据源未提供')) }}
- **{{ labels.turnover_rate_label }}**: {{ snapshot.get('turnover_rate', na('字段待接入')) }}
- **{{ labels.source_label }}**: {{ snapshot.get('source', na('上游映射缺失')) }}
- **{{ session_type_label }}**: {{ snapshot.get('session_type', na('接口未返回')) }}
{% if snapshot.get('consistency_warnings') %}
- **{{ consistency_label }}**:
{% for warning in snapshot.get('consistency_warnings') %}
  - {{ warning }}
{% endfor %}
{% endif %}
{%- endmacro %}
