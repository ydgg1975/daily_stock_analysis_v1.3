# ===================================
# A股自选股智能分析系统 - 配置文件
# ===================================

# --- 1. 基础配置 ---
# 自选股列表 (示例：贵州茅台、宁德时代、比亚迪)
STOCK_LIST=300750,688981,300308,600887,600276,601088,AAPL,NVDA,TSLA,GOLD

# Tushare Token (必须填写真实 Token，不要填链接)
# 获取地址：https://tushare.pro/weborder/#/login?reg=834638
# 如果还没申请，请注释掉下面这行，程序会自动使用备用数据源
TUSHARE_TOKEN=5e81b6164e0f9fd058b5dd8883bcf0bae1962e068c3ac70d72ea903c

# --- 2. AI 模型配置 (核心) ---
# 使用 AIHubMix 聚合平台 (兼容 OpenAI 格式，支持 GPT/Claude/Gemini 等)
AIHUBMIX_KEY=sk-5WoF9juitSNL16hp946dF60bE1964b5dA5B24d5b80B4E079

# 指定使用的模型 (AIHubMix 默认推荐 DeepSeek-V3 或 GPT-4o-mini)
# 格式：provider/model_name
LITELLM_MODEL=openai/gemini-3-flash-preview-free
# 备用模型：主模型限流或失败时自动切换
LITELLM_FALLBACK_MODELS=openai/coding-glm-5-free

# --- 3. 搜索与情报 (可选但推荐) ---
# Tavily API Key (用于搜索最新财经新闻，提升分析质量)
# 免费地址：https://tavily.com/ 注册获取
# 如果没有，请注释掉下面这行，程序会使用备用搜索源
# TAVILY_API_KEYS=your_tavily_api_key_here

# --- 4. 通知渠道 (可选) ---
# 如果你希望结果推送到微信/钉钉，请填写 Webhook URL
# 例如企业微信机器人：WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# 如果没有配置，程序运行结束后会在日志中输出结果，不会发送消息
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=c0a69bc4-a90c-4034-8355-e2f67cf70846 

# --- 5. Agent 策略配置 (默认启用) ---
# 启用趋势、金叉、回踩等策略
AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,shrink_pullback

# --- 6. 定时任务 (GitHub Actions 默认开启) ---
SCHEDULE_ENABLED=true
# 改为盘后执行，确保能获取当日完整行情数据
SCHEDULE_TIME=18:00
RUN_IMMEDIATELY=false
TRADING_DAY_CHECK_ENABLED=false

# --- 7. 其他优化 ---
# 日志级别
LOG_LEVEL=INFO
# 是否启用大盘复盘
MARKET_REVIEW_ENABLED=true
AGENT_MEMORY_ENABLED=true

# --- 8. 性能优化 ---
# 批量预取实时行情，多只股票共享缓存，避免每只股票单独拉取全市场数据
PREFETCH_REALTIME_QUOTES=true

# 实时行情数据源优先级（按顺序尝试，tencent 最稳定，tushare 数据最全需高积分）
REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em
# 启用实时行情（关闭后使用历史收盘价分析）
ENABLE_REALTIME_QUOTE=true
# 盘中实时技术面：用实时价计算 MA/多头排列
ENABLE_REALTIME_TECHNICAL_INDICATORS=true

# --- 9. 回测配置 ---
# 启用回测，追踪历史分析准确率，验证策略有效性
BACKTEST_ENABLED=true
# 回测评估窗口（交易日数）
BACKTEST_EVAL_WINDOW_DAYS=10
# 仅回测 N 天前的分析记录（避免当天/最近数据不完整）
BACKTEST_MIN_AGE_DAYS=14
BACKTEST_ENGINE_VERSION=v1
# 中性区间阈值（%），-2%~+2% 视为震荡
BACKTEST_NEUTRAL_BAND_PCT=2.0

# --- 10. 基本面聚合 ---
# 启用基本面数据聚合，提供更全面的分析维度（PE/PB/营收/净利润等）
ENABLE_FUNDAMENTAL_PIPELINE=true
FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=1.5
FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=0.8
FUNDAMENTAL_RETRY_MAX=1
FUNDAMENTAL_CACHE_TTL_SECONDS=120
FUNDAMENTAL_CACHE_MAX_ENTRIES=256

# --- 11. 东财接口补丁（防封禁）---
# 开启后注入 NID 令牌与随机 User-Agent，降低被东财限流/封禁概率
# 当出现 RemoteDisconnected、连接被关闭等错误时建议开启
ENABLE_EASTMONEY_PATCH=true
