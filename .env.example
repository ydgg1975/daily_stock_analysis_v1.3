# Daily Stock Analysis environment example
#
# Copy this file to `.env` and fill only the values needed for your runtime.
# Do not commit API keys, tokens, passwords, or private webhook URLs.

# ---------------------------------------------------------------------------
# Basic analysis target
# ---------------------------------------------------------------------------

STOCK_LIST=600519,300750,002594

# ---------------------------------------------------------------------------
# Market data sources
# ---------------------------------------------------------------------------

TUSHARE_TOKEN=
# TICKFLOW_API_KEY=

# US stock data sources
# FINNHUB_API_KEY=
# ALPHAVANTAGE_API_KEY=

# Longbridge OpenAPI
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# LONGBRIDGE_CONNECTION_COOLDOWN_SECONDS=15
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
# LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
# LONGBRIDGE_REGION=hk
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

# ---------------------------------------------------------------------------
# LLM basic settings
# ---------------------------------------------------------------------------

# For a quick start, fill one API key. Use LLM channels for multi-provider
# fallback, proxy routing, or provider-specific model lists.
ANSPIRE_API_KEYS=
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6
# ANSPIRE_LLM_ENABLED=true

GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# AIHUBMIX_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Local Ollama example
# OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b

# Optional temperature. Some providers or model families do not accept custom
# temperature, so the runtime may omit or normalize it before sending a request.
# LLM_TEMPERATURE=0.7

# ---------------------------------------------------------------------------
# LLM channel examples
# ---------------------------------------------------------------------------

# Ollama channel
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b,llama3.2

# DeepSeek + Gemini fallback example
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_PROTOCOL=deepseek
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LLM_GEMINI_PROTOCOL=gemini
# LLM_GEMINI_API_KEY=xxx
# LLM_GEMINI_API_KEYS=key1,key2
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview

# OpenAI-compatible proxy example
# LLM_CHANNELS=my_proxy
# LLM_MY_PROXY_PROTOCOL=openai
# LLM_MY_PROXY_BASE_URL=https://your-proxy.example.com/v1
# LLM_MY_PROXY_API_KEY=sk-xxx
# LLM_MY_PROXY_MODELS=gpt-5.5,claude-sonnet-4-6

# Common provider templates
# LLM_CHANNELS=anspire
# LLM_ANSPIRE_PROTOCOL=openai
# LLM_ANSPIRE_BASE_URL=https://open-gateway.anspire.cn/v6
