# ===================================
# Social Sentiment Intelligence (US stocks only)
# ===================================
# Reddit / X (Twitter) / Polymarket sentiment data from api.adanos.org
# Only activates for US stock tickers (AAPL, TSLA, etc.), ignored for A-shares/HK stocks
# Free tier: 250 requests/month | Register: https://api.adanos.org
# SOCIAL_SENTIMENT_API_KEY=sk_live_your_key_here
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# xinwenshixiaoyufenxishaixuanpeizhi
# ===================================
# xinwencelvechuangkoudangwei：ultra_short(1tian) / short(3tian) / medium(7tian) / long(30tian)
# shijichuangkou = min(celvechuangkou, NEWS_MAX_AGE_DAYS)
# NEWS_STRATEGY_PROFILE=short
# xinwenzuidashixiao（tian），sousuoshixianzhijieguozaijinqinei，bimianshiyongguoshixinxi
# NEWS_MAX_AGE_DAYS=3
# guaililvyuzhi（%），pianli MA5 chaoguocizhitishibuzhuigao；qiangshiqushiguzidongfangkuandao 1.5 bei
# BIAS_THRESHOLD=5.0

# ===================================
# Agent celveduihuapeizhi（Web duihuaye）
# ===================================
# qiyong Agent celveduihua（moren false，neibutongyimingmingwei skill）
# AGENT_MODE=true
# Agent zhumoxing（kexuan）：liukongshijichengzhumoxing；wu provider qianzhuihuian openai/<model> jiexi
# AGENT_LITELLM_MODEL=
# Agent zuidatuilibushushangxian（moren 10 shigezi Agent anzishenyusheyunxing；gaoyumoren 10 shisuoyouzi Agent tongyicaiyonggaizhi；diyumouzi Agent morenzhishihuizuoweishangxianjinxingfengding）
# AGENT_MAX_STEPS=10
# morenqiyongcelve（douhaofenge），bupeizhishishiyongyixianeizhimorenzhi
#
# neizhicelvejinengliebiao（kerenyizuhe）：
#   bull_trend          — duotouqushi（MA5>MA10>MA20 pailie + diguaililv）
#   ma_golden_cross     — junxianjincha（MA5 shangchuan MA10/MA20）
#   volume_breakout     — fangliangtupo（jiagetupojinqigaodian + chengjiaoliangfangda）
#   hot_theme           — redianticai（zhengce/chanyeredian、bankuaikuosanyugeguxiangguanxing）
#   event_driven        — shijianqudong（yeji、zhengce、dingdan、binggoudengcuihuashijian）
#   growth_quality      — chengzhangzhiliang（shourulirun、ROE、xianjinliuyuchengzhangchixuxing）
#   expectation_repricing — yuqizhonggu（yeji/zhengce/guzhiyuqichaxiufuhuoluokong）
#   shrink_pullback     — suolianghuicai（huicaijunxian + liangnengweisuo，dixidian）
#   bottom_volume       — dibufangliang（diliangjiandijia，dibufanzhuanxinhao）
#   dragon_head         — longtoucelve（qiangshilongtou，qushiyanxuzhuizhang）
#   one_yang_three_yin  — yiyangjiasanyin（zhulixipanhouqiangshifanbaoxingtai）
#   box_oscillation     — xiangtizhendang（qujiangaopaodixi）
#   chan_theory          — chanlun（chanzhongshuochanlilun：bi/xianduan/zhongshu）
#   wave_theory         — bolanglilun（ailvetebolangjishu）
#   emotion_cycle       — qingxuzhouqi（shichangqingxugaodidianlundong）
#
# liukongshi，xitonghuishiyong metadata lishengmingdezhumorencelve skill（neizhimorenshi bull_trend）
# AGENT_SKILLS=
#
# yekeyishoudongzhidingyizucelve：
# AGENT_SKILLS=bull_trend,ma_golden_cross,shrink_pullback
#
# wanzhengqiyongsuoyouneizhicelve（liangzhongxiefadengxiao）：
# AGENT_SKILLS=all
# AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,hot_theme,event_driven,growth_quality,expectation_repricing,shrink_pullback,bottom_volume,dragon_head,one_yang_three_yin,box_oscillation,chan_theory,wave_theory,emotion_cycle
#
AGENT_SKILLS=
# zidingyicelvemulu（kexuan，fangzhizidingyi YAML celvewenjian；huanjingbianliangmingyanyongneibu skill mingming）
# AGENT_SKILL_DIR=./strategies

# Agent jiagoumoshi（moren single；multi weiduo Agent bianpaimoshi）
# AGENT_ARCH=single

# Multi-Agent bianpaimoshi（jin AGENT_ARCH=multi shiyouxiao）
# quick: jishufenxi→juece（zuikuai，yue 2 ci LLM diaoyong）
# standard: jishu→qingbao→juece（moren）
# full: jishu→qingbao→fengkong→juece
# specialist: jishu→qingbao→fengkong→celvezhuanjiapinggu→juece
# AGENT_ORCHESTRATOR_MODE=standard

# Agent zhixingchaoshiyusuan（miao，0 biaoshiguanbi；single-agent yongzuozhengtixunhuanyusuan，multi-agent yongzuoxiezuobianpaiyusuan；moren 600）
# AGENT_ORCHESTRATOR_TIMEOUT_S=600

# fengkong Agent shifoukeyifoujuemairuxinhao（morenkaiqi）
# AGENT_RISK_OVERRIDE=true

# jiyiyujiaozhunxitong（zhuizonglishizhunquelv，zidongtiaojiezhixindu）
# AGENT_MEMORY_ENABLED=false

# zidonganhuicebiaoxianjiaquancelveyijian
# AGENT_SKILL_AUTOWEIGHT=true

# celveluyoumoshi（auto=genjushichangzhuangtaizidongxuanze / manual=shiyong AGENT_SKILLS liebiao）
# AGENT_SKILL_ROUTING=auto

# shijiangaojingjiankong（schedule moshihoutailunxun；chufahoufuyongyipeizhitongzhiqudao）
# jianrongxingshuoming：benjiejinxinzenggaojingguizepeizhi，buhuixiugaimoxingming、provider、Base URL、LiteLLM huo LLM peizhiyuyi；huituizhixuguanbi/yichushijianjiankongpeizhi。
# zhichiguize：
#   price_cross          — jiagetupoyuzhi，direction: above / below，ziduan: price
#   price_change_percent — zhangdiefuyuzhi，direction: up / down，ziduan: change_pct（danwei：%）
#   volume_spike         — chengjiaoliangfangda，ziduan: multiplier（xiangduijin 20 rijunliangbeishu）
# AGENT_EVENT_MONITOR_ENABLED=false
# AGENT_EVENT_MONITOR_INTERVAL_MINUTES=5
# AGENT_EVENT_ALERT_RULES_JSON=[{"stock_code":"600519","alert_type":"price_cross","direction":"above","price":1800},{"stock_code":"300750","alert_type":"price_change_percent","direction":"down","change_pct":3.0},{"stock_code":"000858","alert_type":"volume_spike","multiplier":2.5}]

# ===================================
# tongzhiqudaopeizhi（ketongshipeizhiduoge，quanbutuisong）
# ===================================
#
# 【fangshiyi】qiyeweixinjiqiren
# zaiqiyeweixinqun -> shezhi -> qunjiqiren -> tianjia -> fuzhi Webhook dizhi
#
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
#
# 【fangshier】feishujiqiren
# zaifeishuqun -> shezhi -> qunjiqiren -> tianjiajiqiren -> zidingyijiqiren -> fuzhi Webhook dizhi
#
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_key_here
# ruguojiqirenanquanshezhikaiqile“qianmingjiaoyan”，xutongbutianxie secret
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# ruguojiqirenanquanshezhikaiqile“guanjianci”，xutianxietongyigeguanjianci；xitonghuizidongzaimeitiaoxiaoxiqianbushang
# FEISHU_WEBHOOK_KEYWORD=gupiaoribao
# zhuyi：FEISHU_APP_ID / FEISHU_APP_SECRET yongyufeishuyingyong、yunwendanghuo Stream moshi，buhuizhijieqiyongqun Webhook tuisong
#
# 【fangshisan】Telegram jiqiren（xutongshipeizhiliangxiang）
# 1. zai Telegram zhao @BotFather -> /newbot -> huoqu Bot Token
# 2. huoqu Chat ID：faxiaoxigei @userinfobot huofangwen https://api.telegram.org/bot<token>/getUpdates
#
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_MESSAGE_THREAD_ID=2780
#
# 【fangshisi】youjiantuisong（zhixu 2 xiangpeizhi，SMTP zidongshibie）
# zhichi QQyouxiang、163youxiang、Gmail dengzhichi SMTP shouquanma/jichurenzhengdeyouxiang
# Outlook / Exchange ruozuhuqiangzhi OAuth2，dangqianbanbenzanbuzhichi
# 1. huoqushouquanma（yiQQyouxiangweili）：shezhi -> zhanghu -> POP3/SMTPfuwu -> kaiqi -> huoqushouquanma
# 2. tianxiexiamianliangxiangjike：
#
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=receiver@example.com  # kexuan，liukongzefageiziji
#
# 【fangshisikuozhan】gupiaofenzufawangbutongyouxiang（Issue #268，kexuan）
# STOCK_LIST juedingshijifenxifanwei；STOCK_GROUP_N jinjuedingyoujianfageishui，jianyishizhongxiecheng STOCK_LIST deziji
# Telegram / qiyeweixin / Webhook dengqitaqudaorenghuianwanzheng STOCK_LIST tuisong，buhuiyinweifenzuerchaifen
# dangqiancangkumoren GitHub Actions daily_analysis workflow buhuizidongzhururenyibianhaode STOCK_GROUP_N / EMAIL_GROUP_N
# yincigainenglishiyongyubendi .env、Docker，huoqitayixianshizhuruzhexiebianliangdeyunxinghuanjing
# STOCK_GROUP_1=600519,300750
# EMAIL_GROUP_1=user1@example.com
# STOCK_GROUP_2=002594,AAPL
# EMAIL_GROUP_2=user2@example.com
#
# 【fangshiwu】zidingyi Webhook（zhichiduoge，douhaofenge）
# shiyongyu：dingding、Discord、Slack、Bark、zijianfuwudengrenyizhichi POST JSON de Webhook
# xitonghuizidongshibiechangjianfuwubingshiyongduiyinggeshi
#
# CUSTOM_WEBHOOK_URLS=https://oapi.dingtalk.com/robot/send?access_token=xxx,https://hooks.slack.com/services/xxx
# CUSTOM_WEBHOOK_BEARER_TOKEN=  # kexuan，yongyuxuyaorenzhengde Webhook (Header Authorization: Bearer <token>)
# CUSTOM_WEBHOOK_BODY_TEMPLATE=  # kexuan，quanju JSON body muban，huifugai Bark/Slack/Discord dengzidong payload；tuijian $content_json/$title_json
# WEBHOOK_VERIFY_SSL=true   # morenjiaoyan；yingxiangduqugaipeizhide webhook-style HTTPS tongzhiqingqiu。shewei false kezhichiziqianmingzhengshu。jinggao：jinyonghoucunzai MITM jiechifengxian，jinxiankexinneiwang
#
# 【fangshiliu】Pushover peizhi
# zhucePushoverzhanghao，bingchuangjianyingyongToken https://pushover.net/apps/build
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=
#
# 【fangshiliukuozhan】ntfy peizhi
# NTFY_URL bixubaohan topic path，liru https://ntfy.sh/my-topic huo https://self-hosted:port/my-topic
# xitonghuijiexi topic，bingshiyong ntfy JSON publish API fasong Markdown wenben。
# NTFY_URL=
# NTFY_TOKEN=  # kexuan，yongyuxuyao Bearer Token de topic huozijian ntfy server
#
# 【fangshiliukuozhan】Gotify peizhi
# GOTIFY_URL shi Gotify server base URL，bubaohan /message；xitonghuipinjie /message bingyong X-Gotify-Key Header fasong token。
# GOTIFY_URL=
# GOTIFY_TOKEN=  # Gotify application token
#
# 【fangshiqi】PushPlus peizhi（guoneituisongfuwu，tuijian）
# zhucePushPluszhanghaobinghuoquToken https://www.pushplus.plus
# PUSHPLUS_TOKEN=
# qunzutuisong：tianxiequnzubianmahou，xiaoxituisonggeiqunzusuoyoudingyueyonghu（yiduiduo）
# PUSHPLUS_TOPIC=
#
# 【fangshiba】Discord peizhi
# zhichiliangzhongfangshi：Webhook（tuijian，peizhijiandan）he Bot API（quanxiangao）
# 
# fangshi1：Discord Webhook（tuijian，wuxu Bot zhanghao）
# zai Discord pindaoshezhi -> jicheng -> Webhook -> xinjian Webhook -> fuzhi URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
# 
# fangshi2：Discord Bot API（xuyao Bot zhanghaohepindao ID）
# 1. chuangjian Bot：https://discord.com/developers/applications -> xinjianyingyong -> Bot -> chuangjian Bot
# 2. huoqu Bot Token：Bot yemian -> zhongzhi Token
# 3. huoqupindao ID：Discord kaiqikaifazhemoshi -> youjianpindao -> fuzhi ID
# DISCORD_BOT_TOKEN=
# DISCORD_MAIN_CHANNEL_ID=
# DISCORD_CHANNEL_ID=   # jianrongjiubianliangming，tuijiangaiyong DISCORD_MAIN_CHANNEL_ID
# ruguoniyaojieshou Discord Interaction / Webhook huidiao，bixupeizhigongyaoyongyuyanqian
# huoqufangshi：Discord Developer Portal -> General Information -> Public Key
# DISCORD_INTERACTIONS_PUBLIC_KEY=
# 
# 【fangshijiu】Slack peizhi
# zhichiliangzhongfangshi：Bot API（tuijian）he Incoming Webhook
# tongshipeizhishiyouxianshiyong Bot API，quebaowenbenyutupianfasongdaotongyipindao。
#
# fangshi1：Slack Bot API（tuijian，zhichitupianshangchuan）
# 1. chuangjian Slack App：https://api.slack.com/apps -> Create New App
# 2. tianjia Bot Token Scopes：chat:write, files:write
# 3. anzhuangdaogongzuoqubinghuoqu Bot Token (xoxb-...)
# 4. huoqupindao ID：pindaoxiangqing -> dibufuzhipindao ID
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C01234567
#
# fangshi2：Slack Incoming Webhook（peizhijiandan，buzhichitupianshangchuan）
# zai Slack App guanliyemianchuangjian Incoming Webhook -> fuzhi URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
#
# 【fangshishi】Serverjiang3 peizhi（guoneituisongfuwu，zhichiweixintuisong）
# zhuceServerjiang3zhanghaobinghuoquSendKey https://sc3.ft07.com/
# SERVERCHAN3_SENDKEY=
#
# 【fangshishiyi】AstrBot peizhi
# ASTRBOT_URL=
# ASTRBOT_TOKEN=  # kexuan，yongyuxuyao Bearer Token de AstrBot Webhook
#
# 【gaojipeizhi】xiaoxichangduxianzhi（zijie）
# chaoguoxianzhihuizidongfenpifasong，yibanwuxuxiugai
# FEISHU_MAX_BYTES=20000    # feishuxianzhiyue 20KB，moren 20000 zijie
# WECHAT_MAX_BYTES=4000     # qiyeweixinxianzhi 4096 zijie，moren 4000 zijie
#
# 【Markdown zhuantupian】(Issue #455)
# duibuzhichi Markdown dequdao，jiangbaogaozhuanweitupianfasong，tishengkeduxing
# dangutuisong + tupian：xutongshipeizhi MARKDOWN_TO_IMAGE_CHANNELS qieanzhuangzhuantugongju
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,wechat,custom,email,slack   # douhaofenge
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000   # chaoguocichangdubuzhuanhuan，bimianchaodatupian
# MD2IMG_ENGINE=wkhtmltoimage   # wkhtmltoimage(moren) | markdown-to-file(emoji genghao，xu npm i -g markdown-to-file)
# zhuantugongju：wkhtmltopdf (apt install wkhtmltopdf / brew install wkhtmltopdf)，huo markdown-to-file
#
# 【tongzhiluyoucelve】(Issue #1200 P3)
# morenliukong：gaileixingtongzhifasongdaosuoyouyipeizhiqudao。tianxiehoujinfasongdaoliechudeyipeizhiqudao。
# yunxuzhi：wechat,feishu,telegram,email,pushover,ntfy,gotify,pushplus,serverchan3,custom,discord,slack,astrbot
# NOTIFICATION_REPORT_CHANNELS=
# NOTIFICATION_ALERT_CHANNELS=
# NOTIFICATION_SYSTEM_ERROR_CHANNELS=
#
# 【tongzhijiangzaojizhi】(Issue #1200 P4)
# morenquanbuguanbi；jinyingxiangjingtaitongzhiqudao，buyingxiangjiqirenchufahuihuahuizhi。
# NOTIFICATION_DEDUP_TTL_SECONDS=0      # tongyiwendingquzhong key zai TTL neizhifasongyici；0 guanbi
# NOTIFICATION_COOLDOWN_SECONDS=0       # tongyilengque key zaichuangkouneixianpin；0 guanbi
# NOTIFICATION_QUIET_HOURS=             # jingmoshiduan，geshi HH:MM-HH:MM，zhichikuawuye
# NOTIFICATION_TIMEZONE=                # jingmoshiduanshiqu，ru Asia/Shanghai；liukonggensui TZ/xitongbendishiqu
# NOTIFICATION_MIN_SEVERITY=            # info,warning,error,critical；liukongbaochixianzhuang
# NOTIFICATION_DAILY_DIGEST_ENABLED=false  # yuliupeizhi；dangqianbuhuifasongmeirizhaiyao
#
# 【shishixingqingyuqu】(Issue #455)
# PREFETCH_REALTIME_QUOTES=true   # shewei false kejinyong，bimian efinance/akshare_em quanshichanglaqu；tushare weidangujiekou，yuqujinlashougu

# ===================================
# dangutuisongpeizhi（kexuan）
# ===================================
# dangutuisongmoshi：meifenxiwanyizhigupiaolijituisong，erbushihuizonghoutuisong
# SINGLE_STOCK_NOTIFY=false
#
# baogaoleixing：simple(jingjian)、full(wanzheng)、brief(3-5jugaikuo)
# Dockerhuanjingxiaruguotuisongneirongbuwanzheng，keyishezhiwei full
# REPORT_TYPE=simple
# baogaoshuchuyuyan：zh(zhongwen，moren) / en(yingwen) / ko(hanwen)
# REPORT_LANGUAGE=zh
# jinfenxijieguozhaiyao：shewei true shizhituisonghuizong，buhangeguxiangqing
# REPORT_SUMMARY_ONLY=false
# tongzhibaogaodibuxianshibencifenxishiyongde LLM moxingmingcheng；shewei false keyincang
# REPORT_SHOW_LLM_MODEL=true
#
# Report Engine P0 (Jinja2 / wanzhengxingjiaoyan / lishiduibi)
# REPORT_TEMPLATES_DIR=templates
# REPORT_RENDERER_ENABLED=false
# REPORT_INTEGRITY_ENABLED=true
# REPORT_INTEGRITY_RETRY=1
# REPORT_HISTORY_COMPARE_N=0

# gegufenxiyudapanfupanhebingtuisong（moren false），jianshaoyoujianshuliang、jiangdilajiyoujianfengxian
# MERGE_EMAIL_NOTIFICATION=false

# ===================================
# fenxijiangepeizhi（kexuan）
# ===================================
# gegufenxihedapanfenxizhijiandeyanchishijian（miao）
# yongyubimianchufa Gemini deng AI API dexianliu
# ANALYSIS_DELAY=0

# yingyong AppKey（yu Webhook moshigongyong）
DINGTALK_APP_KEY=xxxx
# yingyong AppSecret（yu Webhook moshigongyong）
DINGTALK_APP_SECRET=xxxx
# qiyong Stream moshi
DINGTALK_STREAM_ENABLED=false

# feishuyingyongjiqirenpeizhi（yongyu Stream Bot / yunwendangmoshi，buhuizhijiekaiqiqun Webhook tuisong）
FEISHU_APP_ID=xxxx
FEISHU_APP_SECRET=xxxx  # feishuyingyong Secret，jinyingyong/Stream Bot/yunwendangmoshishiyong；quntongzhituisongqingshiyong FEISHU_WEBHOOK_URL
# qiyongzhanglianjiemoshi
FEISHU_STREAM_ENABLED=false
# feishuqunjiqiren Webhook anquanpeizhi（jin Webhook tuisongmoshishiyong）
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# FEISHU_WEBHOOK_KEYWORD=gupiaoribao

# shujukulujing
DATABASE_PATH=./data/stock_analysis.db
# SQLite xieruyouhua：wenjiankumorenqiyong WAL，jiangdipiliangxieruhebingfahuixieshidesuojingzheng
SQLITE_WAL_ENABLED=true
# SQLite dengsuochaoshi（haomiao）
SQLITE_BUSY_TIMEOUT_MS=5000
# SQLite yudao database is locked / database table is locked shidezuidazhongshicishu
SQLITE_WRITE_RETRY_MAX=3
# SQLite xieruzhongshijichutuibishijian（miao，anzhishutuibidizeng）
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# ===================================
# huicepeizhi（kexuan）
# ===================================
# shifouqiyonghuice（true/false）
BACKTEST_ENABLED=true
# huicepingguchuangkou（jiaoyirishu）
BACKTEST_EVAL_WINDOW_DAYS=10
# jinhuice N tianqiandefenxijilu（bimiandangtian/zuijinshujubuwanzheng）
BACKTEST_MIN_AGE_DAYS=14
# huiceyinqingbanben（danghuiceluojishengjishiyongyuqufenjieguo）
BACKTEST_ENGINE_VERSION=v1
# zhongxingqujianyuzhi（%），liru 2 biaoshi -2%~+2% shiweizhendang
BACKTEST_NEUTRAL_BAND_PCT=2.0

# === dingshirenwupeizhi ===
# shifouqiyongdingshirenwu（true/false）
SCHEDULE_ENABLED=false
# meirizhixingshijian（HH:MM geshi，24xiaoshizhi）
SCHEDULE_TIME=18:00
# dingshimoshiqidongshishifoulijizhixingyicifenxi（true/false）
# ruoweixianshishezhi，dingshimoshihuiyanyong RUN_IMMEDIATELY deyunxingshifugaiyuyiyijianrongjiupeizhi
SCHEDULE_RUN_IMMEDIATELY=true
# feidingshimoshiqidongshishifoulijizhixingyicifenxi（true/false）
RUN_IMMEDIATELY=true
# shifouqiyongdapanfupan（true/false）
MARKET_REVIEW_ENABLED=true
# dapanfupanshichangquyu：cn(Agu)、hk(ganggu)、us(meigu)、both(quanbushichang)，hk/us shihejinguanzhuganggu/meigudeyonghu
# MARKET_REVIEW_REGION=cn
# dapanfupanzhishuzhangdieyanse：green_up=lvzhanghongdie（moren），red_up=hongzhanglvdie
# MARKET_REVIEW_COLOR_SCHEME=green_up

# ===================================
# dailipeizhi（kexuan）
# ===================================
# shifouqiyongdaili（true/false，moren false）
# jinzaibendikaifahuanjingshengxiao，GitHub Actions huanjingzidongtiaoguo
USE_PROXY=false
# dailifuwuqidizhi（moren 127.0.0.1）
PROXY_HOST=127.0.0.1
# dailifuwuqiduankou（moren 10809）
PROXY_PORT=10809

# xitongpeizhi
# rizhimulu
LOG_DIR=./logs
# rizhijibie（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
# LiteLLM neiburizhijibie（DEBUG/INFO/WARNING/ERROR/CRITICAL；moren WARNING；paichaneibuliushi/luyouxijieshikelinshishewei DEBUG）
# LITELLM_LOG_LEVEL=WARNING
# zuidabingfaxianchengshu（jianyibaochidibingfafangfengjin）
MAX_WORKERS=3
# shifouqiyongtiaoshirizhi
DEBUG=false

# ===================================
# WebUI peizhi（kexuan）
# ===================================
# shifoumorenqidong WebUI（true/false，moren false）
WEBUI_ENABLED=false
# WebUI jiantingdizhi（moren 127.0.0.1；Docker/yunfuwuqixushewei 0.0.0.0 cainengwaiwangfangwen，xiangjian docs/deploy-webui-cloud.md）
WEBUI_HOST=127.0.0.1
# WebUI jiantingduankou（moren 8000）
WEBUI_PORT=8000
# qidong Web fuwuqianshifouzidonggoujianqianduan（npm install && npm run build，moren true）
WEBUI_AUTO_BUILD=true
# dancengkexinfanxiangdaili（ru Nginx → App）xiaxinren X-Forwarded-For huoquzhenshi IP，quzuiyouzhiyongyudengluxianliu；duojidaili/CDN changjingxianliu key kenengtuihuaweibianyuandaili IP，xuewaipinggu；zhiliangongwangshibaochi false fangweizao
# TRUST_X_FORWARDED_FOR=false

# ===================================
# Web denglurenzheng（kexuan）
# ===================================
# shewei true qiyongmimabaohu；shoucifangwenshizaiwangyeshezhichushimima，kezai「xitongshezhi > xiugaimima」zhongxiugai
# wangjimimakezaifuwuqizhixing: python -m src.auth reset_password
ADMIN_AUTH_ENABLED=false
# ADMIN_SESSION_MAX_AGE_HOURS=24  # Session youxiaoqi（xiaoshi）

# ===========================================
# tupianshibiegupiaodaima（shezhiye「congtupiantianjia」）
# ===========================================
# danciqingqiuchaoshi 60 miao；tupianzuida 5MB
# xupeizhi GEMINI_API_KEY、ANTHROPIC_API_KEY huo OPENAI_API_KEY zhongzhishaoyige（Vision nenglimoxing）

# ===========================================
# Data Fetcher Priority Configuration
# ===========================================
# Lower number = higher priority (tried first)
# Default priorities: efinance(0) > akshare(1) > tushare/pytdx(2) > baostock(3) > yfinance(4)
# For US stocks, set YFINANCE_PRIORITY=0 to use Yahoo Finance first

# EFINANCE_PRIORITY=0      # EastMoney (China) - default: 0
# EFINANCE_CALL_TIMEOUT=30 # Timeout (seconds) for efinance API calls; prevents indefinite hangs
#                          # when eastmoney hosts are unreachable. Default: 30
# AKSHARE_PRIORITY=1       # AkShare (China) - default: 1
# TUSHARE_PRIORITY=2       # Tushare Pro (China) - default: 2
# PYTDX_PRIORITY=2         # Tongdaxin (China) - default: 2
#
# Pytdx custom server (for intranet/deploy): use custom host instead of built-in public servers
# PYTDX_HOST=192.168.1.100
# PYTDX_PORT=7709
# Or multiple servers: PYTDX_SERVERS=ip1:port1,ip2:port2
# BAOSTOCK_PRIORITY=3      # Baostock (China) - default: 3
# YFINANCE_PRIORITY=4      # Yahoo Finance (Global) - default: 4

# Example: Prioritize Yahoo Finance for US stocks
# YFINANCE_PRIORITY=0
# EFINANCE_PRIORITY=99

# ===========================================
# shishixingqingshujuyuanyouxianjipeizhi
# ===========================================
# yongyuhuoquliangbi、huanshoulv、shiyinglvdengshishishuju
# kexuanshujuyuan（douhaofenge，anshunxuchangshi）：
#   - tencent: tengxuncaijing，youliangbi/huanshoulv/PE/PB，danguchaxunwending（tuijianshouxuan）
#   - akshare_sina: xinlangcaijing，jibenhangqing，wuliangbi，danfeichangwending
#   - efinance: dongcai(efinanceku)，youliangbi，quanlianglaquyibeifeng
#   - akshare_em: dongcai(akshareku)，shujuzuiquan，quanlianglaquyibeifeng
#   - tushare: Tushare Pro，xuyao2000jifen，shujuquanmian（fufeiyonghutuijian）
#
# morenyouxianji：tencent > akshare_sina > efinance > akshare_em
# ruguoyou Tushare Pro gaojifenzhanghao，kejiang tushare fangzaishouwei：
# REALTIME_SOURCE_PRIORITY=tushare,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# shifouqiyongshishixingqing（guanbihoushiyonglishishoupanjiafenxi）
# ENABLE_REALTIME_QUOTE=true

# panzhongshishijishumian：qiyongshiyongshishijiajisuan MA/duotoupailie（Issue #234）；guanbizeyongzuorishoupan
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true

# shifouqiyongchoumafenbu（gaijiekoubuwending，yunduanbushujianyiguanbi）
