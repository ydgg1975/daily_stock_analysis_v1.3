# zixuanguliebiao（douhaofenge，zhichihushenliangshidaima）
# hushi：600xxx, 601xxx, 603xxx
# shenshi：000xxx, 002xxx, 300xxx
STOCK_LIST=600519,300750,002594

# Anspire Open API Keys（zhichiduoge，douhaofenge）
# huoqu: https://open.anspire.cn/?share_code=QFBC0FYC
# zaiweipeizhigenggaoyouxianji OpenAI-compatible laiyuanshi，manzutiaojiankefuyonggai key gei Anspire damoxingwangguanyuxinwensousuo。
# xialiewangguanyumoxingweidangqianxiangmushilipeizhi；shifoukeyongqingyi Anspire kongzhitaiyuguanfangwendangweizhun：
# shiliwangguan： https://open-gateway.anspire.cn/v6
# shilimoxing：Doubao-Seed-2.0-lite（kefugaiwei ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-pro）
# ruowangguanyouquyu/banbenchayi，kefugaiwei ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.ai/v6
ANSPIRE_API_KEYS=
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6
# ANSPIRE_LLM_ENABLED=true
# shujuyuanpeizhi
# Tushare Pro Token（kexuan，cong https://tushare.pro/weborder/#/login?reg=834638 huoqu）
TUSHARE_TOKEN=
# TickFlow API Key（kexuan，yongyu A gudapanfupanzhishuzengqiang；ruotaocanzhichibiaodichichaxun，yekezengqiangshichangtongji）
# TICKFLOW_API_KEY=

# Finnhub（kexuan，meigushujuyuan，mianfei tier 60 calls/min）
# huoqu: https://finnhub.io/register
# FINNHUB_API_KEY=

# AlphaVantage（kexuan，meigushujuyuan，mianfei tier 25 calls/day）
# huoqu: https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=

# Longbridge OpenAPI（kexuan，meigu/gangguliangbi、huanshoulv、PE dengziduandoudi）
# cong https://open.longbridge.com/ huoqu
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# static_info jinchengneihuancunmiaoshu，moren 86400；0=meiciqingqiulaqu
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# lianjieguanbileiyichanghoudelengquemiaoshu，moren 15；lengqueqineihuilinshitiaoguo Longbridge，bimianqingqiujipinfanzhonglian
# LONGBRIDGE_CONNECTION_COOLDOWN_SECONDS=15
# Longbridge SDK yuyanyu REPORT_LANGUAGE（zh/en/ko）yizhi；SDK rizhixieru LOG_DIR/longbridge_sdk.log
# jierudian（yu REPORT_LANGUAGE wuguan；liukongzeyongxialiemorenzhi）：
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
# LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
# LONGBRIDGE_REGION=hk
# fugaijierudian；SDK neibuyong LONGPORT_REGION（budai BRIDGE）zidongxuanze，
# daimahuizidongtongbu LONGBRIDGE_REGION → LONGPORT_REGION。
# hk → *.longbridge.com  |  cn → *.longbridge.cn
# qiyujian：https://open.longbridge.com/zh-CN/docs/getting-started#huanjingbianliang
# yepanhangqing true/false，moren false
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# K xiantuisong realtime huo confirmed，moren realtime
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# lianjieshishifoudayinhangqingbao（yu README / full-guide yizhi：weishezhishiyingyongcemorenweiguanbi，dengtong false）
# shewei 1 / true / yes kaiqi SDK xiangxihangqingbaorizhi（tiaoshizhangqiaolianjieshishiyong）
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

